@namespace iPath.Blazor.Componenets.Admin.Events
@using iPath.Application.Features.Admin
@using iPath.Application.Features.Notifications

<MudDataGrid T="EventDto" Items="@Events" Dense="true" Hover="true" Striped="true">
    <Columns>
        <PropertyColumn Property="x => x.EventDate" Title="Date">
            <CellTemplate>
                @context.Item.EventDate.ToString("g")
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.EventName" Title="Type" />
        <PropertyColumn Property="x => x.UserId" Title="User">
            <CellTemplate>
                @context.Item.UserId
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ObjectName" Title="Object" />
        <TemplateColumn Title="Notif">
            <CellTemplate>
                @if ((context.Item.NotificationsCount ?? 0) > 0)
                {
                    <MudBadge Content="@context.Item.NotificationsCount" Color="Color.Primary"
                              OnClick="@(() => OnNotificationClick.InvokeAsync(context.Item.EventId))">
                        <MudIcon Icon="@Icons.Material.Filled.Notifications" />
                    </MudBadge>
                }
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter]
    public Guid ServiceRequestId { get; set; }

    [Parameter]
    public IEnumerable<EventDto> Events { get; set; } = [];

    [Parameter]
    public EventCallback<Guid> OnNotificationClick { get; set; }
}
