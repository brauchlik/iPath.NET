@page "/admin/servicerequest/{id}/events"
@attribute [Authorize(Roles = "Admin,Developer")]

@using iPath.Application.Features.Admin
@using iPath.Application.Features.ServiceRequests
@using iPath.Blazor.ServiceLib.ApiClient
@using iPath.Domain.Entities

@inject IPathApi api
@inject ISnackbar snackbar
@inject NavigationManager nm

<MudStack Row="true" Spacing="2" Class="mb-4">
    <MudText Typo="Typo.h5">Events & Notifications</MudText>
</MudStack>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_serviceRequest is null)
{
    <MudAlert Severity="MudBlazor.Severity.Warning">ServiceRequest not found</MudAlert>
}
else
{
    <MudPaper Class="mb-4 p-2">
        <div class="ipath_node">
            <div class="ipath_node_title">
                <div class="ipath_bold">
                    <MudHighlighter Text="@_serviceRequest.Title" />
                    <MudHighlighter Text="@_serviceRequest.Description.BodySite?.ToAppend()" />
                </div>
                <div>@_serviceRequest.SubTitle</div>
            </div>
            <div class="ipath_node_type">
                <div class="ipath_bold">Type:</div>
                <div>@_serviceRequest.CaseType</div>
            </div>
            <div class="ipath_node_sender">
                <div class="ipath_bold">Sender:</div>
                <OwnerLink Owner="@_serviceRequest.Owner" />
            </div>
            <div class="ipath_node_date">
                <b><GroupLink GroupId="@_serviceRequest.GroupId" /></b>
                <div>@_serviceRequest.CreatedOn.ToString("d")</div>
            </div>
        </div>
    </MudPaper>

    <MudTabs Elevation="2" ApplyEffectsToContainer="true" PanelClass="pa-4" @bind-ActivePanelIndex="activeTabIndex">
        <MudTabPanel Text="@($"Events ({Events?.Count ?? 0})")" Icon="@Icons.Material.Filled.History">
            <ServiceRequestEventsGrid ServiceRequestId="@ServiceRequestId" Events="@Events" OnNotificationClick="SwitchToNotificationsTab" />
        </MudTabPanel>
        <MudTabPanel Text="@($"Notifications ({FilteredNotifications?.Count ?? 0})")" Icon="@Icons.Material.Filled.Notifications">
            @if (EventIdFilter is not null)
            {
                var eventIdStr = EventIdFilter.Value.ToString();
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" 
                          OnClick="ClearEventIdFilter" Class="mb-2">
                    Event: @eventIdStr[..8] <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                </MudButton>
            }
            <ServiceRequestNotificationsGrid ServiceRequestId="@ServiceRequestId" Notifications="@FilteredNotifications" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter]
    public string id { get; set; } = string.Empty;

    [Parameter]
    public string? eventId { get; set; }

    private Guid ServiceRequestId => Guid.TryParse(id, out var result) ? result : Guid.Empty;
    private Guid? EventIdFilter => string.IsNullOrEmpty(eventId) ? null : Guid.TryParse(eventId, out var e) ? e : null;

    private List<EventDto>? Events { get; set; }
    private List<NotificationDto>? Notifications { get; set; }
    private List<NotificationDto>? FilteredNotifications => EventIdFilter is null 
        ? Notifications 
        : Notifications?.Where(n => n.EventId == EventIdFilter).ToList();
    private bool isLoading = true;
    private int activeTabIndex = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        isLoading = false;
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var srResp = await api.GetRequestById(ServiceRequestId);
            if (srResp.IsSuccessful && srResp.Content is not null)
            {
                _serviceRequest = srResp.Content;
            }
            else
            {
                snackbar.AddWarning("ServiceRequest not found");
                return;
            }

            var eventsResp = await api.GetServiceRequestEvents(ServiceRequestId);
            if (eventsResp.IsSuccessful)
            {
                Events = eventsResp.Content;
            }
            else
            {
                snackbar.AddWarning(eventsResp.ErrorMessage);
            }

            var notifResp = await api.GetServiceRequestNotifications(ServiceRequestId, EventIdFilter);
            if (notifResp.IsSuccessful)
            {
                Notifications = notifResp.Content;
            }
            else
            {
                snackbar.AddWarning(notifResp.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            snackbar.AddError(ex.Message);
        }
    }

    private void SwitchToNotificationsTab(Guid eventId)
    {
        var eventIdStr = eventId.ToString();
        nm.NavigateTo($"/admin/servicerequest/{id}/events?eventId={eventIdStr}", forceLoad: false);
    }

    private void ClearEventIdFilter()
    {
        nm.NavigateTo($"/admin/servicerequest/{id}/events");
    }

    private ServiceRequestDto? _serviceRequest;
    private string RequestTitle => _serviceRequest?.Title ?? "Loading...";
}
