@if (Items is not null)
{
    @foreach (var a in Items.OrderByDirection(Sort, a => a.CreatedOn))
    {
        @if (ShowAnnotations)
        {
            <AnnotationItemView Item="a" OnDelete="OnDelete" OnReply="OnReply" OnEdit="OnEdit" />
        }
        else
        {
            <AnnotationSkeleton />
        }
    }
}

@inject ServiceRequestViewModel vm

@code {
    [Parameter]
    public ICollection<AnnotationDto>? Items { get; set; }

    [Parameter]
    public bool ShowAnnotations { get; set; }

    [Parameter]
    public SortDirection Sort { get; set; }

    // [Parameter]
    // public EventCallback<AnnotationDto> OnDelete { get; set;  }
        

    async Task OnDelete(AnnotationDto item)
    {
        await vm.DeleteAnnotation(item);
        await vm.ReloadNode();
    }

    async Task OnEdit(AnnotationDto item)
    {
        // await vm.DeleteAnnotation(item);
        // await vm.ReloadNode();
    }

    async Task OnReply(AnnotationDto item)
    {
        // await vm.DeleteAnnotation(item);
        // await vm.ReloadNode();
    }
}
