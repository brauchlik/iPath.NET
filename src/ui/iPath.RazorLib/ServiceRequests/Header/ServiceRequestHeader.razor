@namespace iPath.Blazor.Componenents.ServiceRequests

@inherits ServiceRequestViewComponentBase

<MudSwipeArea OnSwipeEnd="OnSwipeHandler">
    <div class="mud-theme-info ipath_node_header">
        <div class="ipath_header_title">@Title</div>
        <div class="ipath_header_actions">
            <MudIconButton OnClick="vm.GoPrevious" Icon="@Icons.Material.Filled.ArrowLeft" Size="Size.Small" Title="Previous" />
            <MudIconButton OnClick="vm.GoUp" Icon="@Icons.Material.Filled.ArrowDropUp" Size="Size.Small" Title="Up" />
            <MudIconButton OnClick="vm.GoNext" Icon="@Icons.Material.Filled.ArrowRight" Size="Size.Small" Title="Next" />
        </div>
        <div class="ipath_header_toolbar">
            <MudToolBar WrapContent="true">
                <MudTooltip Text=@T["edits"]>
                    <IPathToolbarButton Icon="@EditIcon" OnClick="OnEditClick" Disabled="vm.EditDisabled" />
                </MudTooltip>
                <IPathToolbarButton Icon="@Icons.Material.Outlined.Save" OnClick="@(() => vm.Save())" Hidden="@hideSave" />
                <MudTooltip Text=@T["Upload Files"]>
                    <FileUploadButton Disabled="@vm.AttachFileDisabled" Icon="@Icons.Material.Filled.DriveFolderUpload" />
                </MudTooltip>
                <MudButtonGroup>
                    <MudMenu Icon="@Icons.Material.Filled.AttachFile" Style="align-self: auto;">
                        @if (vm.DocumentImportEnabled)
                        {
                            <MudMenuItem Icon="@Icons.Material.Filled.ImportExport" OnClick="@(() => vm.ExternalDocumentImport())">Import from Google</MudMenuItem>
                        }
                        <MudMenuItem Icon="@Icons.Material.Filled.Folder">Folder</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.DynamicForm">Form</MudMenuItem>
                    </MudMenu>
                </MudButtonGroup>
                <MudTooltip Text=@T["add a comment"]>
                    <IPathToolbarButton Icon="@Icons.Material.Outlined.AddComment" OnClick="@(() => vm.StartAnnotation())" Disabled="vm.AnnotateDisabled" />
                </MudTooltip>

                <IPathToolbarButton Icon="@Icons.Material.Outlined.Fullscreen" Href="@vm.SlideShowUrl" Disabled=@(!vm.HasSlideShow)
                                    Tooltip=@T["Show images in fullscreen mode"] />
                @if (vm.CanMoveRequest)
                {
                    <MudTooltip Text=@T["move to another group"]>
                        <IPathToolbarButton Icon="@Icons.Material.Outlined.DriveFileMove" OnClick="@(() => vm.MoveRequest())" />
                    </MudTooltip>
                }
                <MudTooltip Text=@T["delete"]>
                    <IPathToolbarButton Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => vm.Delete())" Disabled="vm.DeleteDisabled" />
                </MudTooltip>

                @if (vm.IsAdmin)
                {
                    <MudSpacer />
                    @if (vm.HasPreviewPlugin)
                    {
                        <IPathToolbarButton Icon="@Icons.Material.Outlined.Preview" OnClick="@(() => vm.ShowPreviewDialog())" />
                    }

                    <MudTooltip Text=@T["View Events & Notifications"]>
                        <MudIconButton Icon="@Icons.Material.Outlined.History"
                                       Href="@($"/admin/servicerequest/{vm.SelectedRequest?.Id}/events")" />
                    </MudTooltip>
                    
                    <MudTooltip Text=@T["Show deleted data (documents & annotations)"]>
                        <MudToggleIconButton Icon="@ShowDeletedIcon" Color="@ShowDeletedColor"
                                             @bind-Toggled="vm.ShowDeleted" @bind-Toggled:after="vm.ReloadNode" />
                    </MudTooltip>

                    @if (vm.ExternalStorageActive)
                    {
                        <MudTooltip Text=@T["sync data with external storage"]>
                            <MudIconButton Icon="@Icons.Material.Outlined.Sync" OnClick="vm.SyncExternalStorage" />
                        </MudTooltip>
                    }
                }
            </MudToolBar>
        </div>
    </div>
</MudSwipeArea>


@code {
    bool hideSave => !vm.IsEditing;

    private string EditIcon => vm.IsEditing ? Icons.Material.Outlined.Cancel : Icons.Material.Outlined.Edit;


    async Task OnSwipeHandler(SwipeEventArgs args)
    {
        if (args.SwipeDirection == SwipeDirection.RightToLeft)
        {
            await vm.GoNext();
        }
        else if (args.SwipeDirection == SwipeDirection.LeftToRight)
        {
            await vm.GoNext();
        }
    }



    async Task OnEditClick()
    {
        if (vm.IsEditing)
            await vm.CancelEdit();
        else
            await vm.Edit();
    }


    string Title
    {
        get
        {
            if (vm.SelectedRequest is null)
                return T["loading ..."];
            else if (vm.SelectedRequest.IsDraft)
                return T["New Case"];

            var ret = vm.SelectedRequest.Title;

            if (!vm.IsRootNodeSelected && vm.SelectedDocument is not null)
            {
                ret += " >> " + vm.SelectedDocument.File?.Filename;
            }

            return ret;
        }
    }


    protected Color ShowDeletedColor => vm.ShowDeleted ? Color.Warning : Color.Default;
    protected string ShowDeletedIcon => vm.ShowDeleted ? Icons.Material.Filled.DeleteSweep : Icons.Material.Outlined.DeleteOutline;
}
